{
	"name": "vankosoft/application-bundle",
    "type": "symfony-bundle",
    "description": "Symfony VSApplicationBundle",
    "keywords": ["Symfony Application"],
    "homepage": "https://github.com/iatanasov77/vs-application-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Ivan I. Atanasov",
            "email": "i.atanasov77@gmail.com"
        }
    ],
    "require": {
        "php": "^7.2"
        
    },
    "suggest": {
        "monolog/monolog": "Allows more advanced logging of the application flow",
        "symfony/debug-bundle": "Allows developement debugging",
        "symfony/maker-bundle": "Standard symfony console maker tools",
        "symplify/changelog-linker": "Allows generation of nice CHANGELOG.md file"
    },
    "conflict": {
        "doctrine/doctrine-bundle": "<1.3",
        "symfony/doctrine-bridge": "<2.7"
    },
    "autoload": {
        "psr-4": {
            "VS\\ApplicationBundle\\": "lib/"
        }
    },
    "minimum-stability" : "dev"
}
